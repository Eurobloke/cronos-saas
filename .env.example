# ─── Seguridad ───────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esta-clave-secreta-en-produccion-32chars

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///cronos.db

# ─── Email (Gmail: activa "contraseña de aplicación") ────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
MAIL_DEFAULT_SENDER=Cronos AI <tu_correo@gmail.com>

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=tu_client_id_de_paypal
PAYPAL_CLIENT_SECRET=tu_client_secret_de_paypal
PAYPAL_MODE=sandbox

# ─── Aplicación ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:5000
APP_NAME=Cronos AI
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=Admin123!

# ─── Ruta a los bots ─────────────────────────────────────────────────────────
BOTS_DIR=C:\Users\franc\music

# ─── IA Orquestador (Claude API) ─────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com/
# Sin esta clave, el asistente usará Ollama local como respaldo
ANTHROPIC_API_KEY=tu_clave_anthropic_aqui

# ─── YouTube OAuth (para que clientes conecten su canal) ─────────────────────
# Crea credenciales en: https://console.cloud.google.com/
# Tipo: Web Application, URI de redirección: http://localhost:5000/dashboard/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/dashboard/youtube/callback
